{
  "Logging": {
    "LogLevel": {
        "Default": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "MassTransit": "Information"
    }
  },
  "ConnectionStrings": {
    "receiptflow": "Host=localhost;Database=receiptflow;Username=receiptflow;Password=__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__",
    "messaging": "__SET_BY_ASPIRE_OR_USER_SECRETS__"
  },
  "Messaging": {
    "Transport": "RabbitMQ"
  },
  "DocumentStorage": {
    "Provider": "AzureBlob",
    "ContainerName": "receipt-documents",
    "BlobConnectionName": "blobs",
    "RootPath": "__SET_DOCUMENT_STORAGE_ROOT__"
  },
    "Nvidia": {
        "Endpoint": "https://integrate.api.nvidia.com/v1/chat/completions",
        "Model": "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning",
        "MaxPdfPages": 5,
        "MinimumConfidence": 0.70
    },
  "ReceiptSearch": {
    "ChunkSize": 1000,
    "ChunkOverlap": 150
  },
    "NvidiaEmbeddings": {
        "Endpoint": "https://integrate.api.nvidia.com/v1/embeddings",
        "Model": "nvidia/llama-nemotron-embed-1b-v2",
        "Dimensions": 1024,
        "BatchSize": 16
    },
    "Typesense": {
        "Endpoint": "__SET_BY_ASPIRE_OR_ENVIRONMENT__",
		"CollectionName": "receipt_chunks_v1",
        "EmbeddingDimensions": 1024
    }

}
