{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Keycloak": {
    "Authority": "https://localhost:6001/realms/receipt",
    "Audience": "receiptflow-api",
    "RequireHttpsMetadata": true
  },
  "ConnectionStrings": {
    "receiptflow": "Host=localhost;Database=receiptflow;Username=receiptflow;Password=__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__"
  },
  "DocumentStorage": {
    "Provider": "Local",
    "ContainerName": "receipt-documents",
    "BlobConnectionName": "blobs",
    "RootPath": "__SET_DOCUMENT_STORAGE_ROOT__"
  },
  "Messaging": {
    "Transport": "RabbitMQ"
  },
  "AIProviders": {
    "Extraction": "Nvidia",
    "Embeddings": "Nvidia",
    "AnswerGeneration": "Nvidia"
  },
  "AI": {
    "AnswerProvider": "Nvidia"
  },
  "ReceiptSearch": {
    "ChunkSize": 1000,
    "ChunkOverlap": 150
  },
  "NvidiaEmbeddings": {
    "Endpoint": "__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__",
    "Model": "__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__",
    "Dimensions": 1024,
    "BatchSize": 16
  },
  "NvidiaChat": {
    "Endpoint": "__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__",
    "Model": "__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__",
    "MaximumOutputTokens": 512,
    "Temperature": 0.1
  },
  "Typesense": {
    "Endpoint": "__SET_BY_ASPIRE_OR_ENVIRONMENT__",
    "CollectionName": "receipt_chunks_v1",
    "EmbeddingDimensions": 1024
  },
  "AllowedHosts": "*"
}
