{
  "Logging": {
    "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "MassTransit": "Information"
    }
  },
    "Keycloak": {
        "Authority": "https://localhost:6001/realms/receipt",
        "Audience": "receipt",
        "RequireHttpsMetadata": false
    },
  "ConnectionStrings": {
    "receiptflow": "Host=localhost;Database=receiptflow;Username=receiptflow;Password=__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__"
  },
  "DocumentStorage": {
    "Provider": "AzureBlob",
    "ContainerName": "receipt-documents",
    "BlobConnectionName": "blobs",
    "RootPath": "__SET_DOCUMENT_STORAGE_ROOT__"
  }
}
