{
  "Logging": {
    "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "MassTransit": "Information"
    }
  },
    "Keycloak": {
        "Authority": "https://localhost:6001/realms/receipt",
        "Audience": "receipt",
        "RequireHttpsMetadata": false
    },
  "ConnectionStrings": {
    "receiptflow": "Host=localhost;Database=receiptflow;Username=receiptflow;Password=__SET_VIA_USER_SECRETS_OR_ENVIRONMENT__"
  },
  "DocumentStorage": {
    "Provider": "AzureBlob",
    "ContainerName": "receipt-documents",
    "BlobConnectionName": "blobs",
    "RootPath": "__SET_DOCUMENT_STORAGE_ROOT__"
  },
  "ReceiptSearch": {
    "ChunkSize": 1000,
    "ChunkOverlap": 150
  },
  "NvidiaEmbeddings": {
    "Endpoint": "https://integrate.api.nvidia.com/v1/embeddings",
    "Model": "nvidia/llama-nemotron-embed-1b-v2",
    "Dimensions": 1024,
    "BatchSize": 16
  },
  "Typesense": {
    "Endpoint": "__SET_BY_ASPIRE_OR_ENVIRONMENT__",
    "CollectionName": "receipt_chunks_v1",
    "EmbeddingDimensions": 1024
  }
}
